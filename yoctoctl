# Display comprehensive environment status report
cmd_status() {
    show_banner
    
    gum style \
        --foreground "$COLOR_DARK" \
        --bold \
        --align center \
        "INFRASTRUCTURE STATUS REPORT"
    
    echo ""
    echo ""
    
    # Network Configuration Section
    gum style --foreground "$COLOR_DARK" --bold "Network Configuration"
    echo ""
    
    local network_status
    network_status=$(check_network_status)
    local net_state="${network_status%%:*}"
    local port_state="${network_status##*:}"
    
    printf "  %-24s : " "Endpoint Address"
    if [[ "$net_state" == "active" ]]; then
        gum style --foreground "$COLOR_SUCCESS" "$SMB_ENDPOINT [Active]"
    else
        gum style --foreground "$COLOR_ERROR" "$SMB_ENDPOINT [Inactive]"
    fi
    
    printf "  %-24s : " "SMB Port Status"
    if [[ "$port_state" == "accessible" ]]; then
        gum style --foreground "$COLOR_SUCCESS" "Port $SMB_PORT [Accessible]"
    else
        gum style --foreground "$COLOR_WARNING" "Port $SMB_PORT [Unreachable]"
    fi
    
    echo ""
    echo ""
    
    # Container Infrastructure Section
    gum style --foreground "$COLOR_DARK" --bold "Container Infrastructure"
    echo ""
    
    for container_def in \
        "$FILESERVER_CONTAINER:File Server:SMB file sharing service" \
        "$BUILDER_CONTAINER:Build Engine:Yocto compilation environment"; do
        
        IFS=':' read -r container display desc <<< "$container_def"
        local status_info
        status_info=$(get_container_status "$container")
        local status="${status_info%%:*}"
        local since="${status_info##*:}"
        
        printf "  %-24s : " "$display"
        
        case "$status" in
            running)
                gum style --foreground "$COLOR_SUCCESS" "● Running (since $since)"
                ;;
            stopped|exited)
                gum style --foreground "$COLOR_WARNING" "○ Stopped"
                ;;
            missing)
                gum style --foreground "$COLOR_ERROR" "✗ Not Deployed"
                ;;
            *)
                gum style --foreground "$COLOR_MUTED" "◌ Unknown"
                ;;
        esac
        
        printf "  %-24s   %s\n" "" "$(gum style --foreground "$COLOR_MUTED" "$desc")"
    done
    
    echo ""
    echo ""
    
    # Storage Infrastructure Section
    gum style --foreground "$COLOR_DARK" --bold "Storage Infrastructure"
    echo ""
    
    local storage_info
    storage_info=$(analyze_storage)
    IFS=':' read -r vol_status total used percent files dirs <<< "$storage_info"
    
    printf "  %-24s : " "Workspace Volume"
    if [[ "$vol_status" == "missing" ]]; then
        gum style --foreground "$COLOR_ERROR" "✗ Not Created"
    else
        gum style --foreground "$COLOR_SUCCESS" "● Operational"
        if [[ "$total" != "unknown" ]]; then
            printf "  %-24s   %s\n" "" \
                "$(gum style --foreground "$COLOR_MUTED" "Capacity: $total | Used: $used ($percent)")"
            if [[ "$files" != "0" ]] || [[ "$dirs" != "0" ]]; then
                printf "  %-24s   %s\n" "" \
                    "$(gum style --foreground "$COLOR_MUTED" "Contents: $files files, $dirs directories")"
            fi
        fi
    fi
    
    echo ""
    echo ""
    
    # Environment Summary
    gum style --foreground "$COLOR_DARK" --bold "Environment Summary"
    echo ""
    
    if docker ps -q -f "name=yocto-" | grep -q .; then
        gum style --foreground "$COLOR_SUCCESS" "  ✓ Environment Operational"
        echo ""
        gum style --foreground "$COLOR_INFO" "  Access Methods:"
        printf "    %-20s : %s\n" "Development Shell" "$SCRIPT_NAME shell"
        printf "    %-20s : %s\n" "File System" "smb://$SMB_ENDPOINT/workdir"
        printf "    %-20s : %s\n" "macOS Finder" "⌘+K → smb://$SMB_ENDPOINT/workdir"
    else
        gum style --foreground "$COLOR_WARNING" "  ⚠ Environment Requires Initialization"
        echo ""
        printf "    %s\n" "$(gum style --foreground "$COLOR_MUTED" "Initialize with: $SCRIPT_NAME start")"
    fi
}

# Initialize environment with comprehensive orchestration
cmd_start() {
    show_banner
    
    gum style \
        --foreground "$COLOR_DARK" \
        --bold \
        --align center \
        "ENVIRONMENT INITIALIZATION"
    
    echo ""
    echo ""
    
    # Phase 1: Network Configuration
    gum style --foreground "$COLOR_INFO" "[1/3] Network Configuration"
    if configure_network; then
        gum style --foreground "$COLOR_SUCCESS" "  ✓ Network interface configured"
    else
        gum style --foreground "$COLOR_ERROR" "  ✗ Network configuration failed"
        return 1
    fi
    
    echo ""
    
    # Phase 2: Container Startup
    gum style --foreground "$COLOR_INFO" "[2/3] Container Startup"
    local failed
    failed=$(start_containers)
    
    if [[ $failed -eq 0 ]]; then
        gum style --foreground "$COLOR_SUCCESS" "  ✓ All containers started"
    else
        gum style --foreground "$COLOR_WARNING" "  ⚠ Some containers failed"
    fi
    
    echo ""
    
    # Phase 3: Service Verification
    gum style --foreground "$COLOR_INFO" "[3/3] Service Verification"
    
    if gum spin --spinner dot \
        --title "Waiting for file server..." \
        -- bash -c "wait_for_fileserver"; then
        gum style --foreground "$COLOR_SUCCESS" "  ✓ File server ready"
    else
        gum style --foreground "$COLOR_WARNING" "  ⚠ File server timeout"
    fi
    
    if nc -z "$SMB_ENDPOINT" "$SMB_PORT" 2>/dev/null; then
        gum style --foreground "$COLOR_SUCCESS" "  ✓ SMB service accessible"
    else
        gum style --foreground "$COLOR_WARNING" "  ⚠ SMB service not responding"
    fi
    
    echo ""
    echo ""
    
    # Completion Summary
    gum style --foreground "$COLOR_SUCCESS" --bold --align center \
        "✓ ENVIRONMENT READY"
    
    echo ""
    gum style --foreground "$COLOR_INFO" --align center "Quick Start:"
    echo ""
    printf "  %s : %s\n" \
        "$(gum style --foreground "$COLOR_MUTED" "Connect to shell")" \
        "$SCRIPT_NAME shell"
    printf "  %s : %s\n" \
        "$(gum style --foreground "$COLOR_MUTED" "Mount in Finder")" \
        "⌘+K → smb://$SMB_ENDPOINT/workdir"
}

# Connect to development shell environment
cmd_shell() {
    if ! docker ps -q -f "name=$BUILDER_CONTAINER" | grep -q .; then
        gum style --foreground "$COLOR_WARNING" "Build container not running"
        
        if gum confirm "Start the environment?"; then
            cmd_start
            echo ""
        else
            return 1
        fi
    fi
    
    gum style \
        --foreground "$COLOR_INFO" \
        --align center \
        "Connecting to Poky Development Environment"
    
    sleep 0.5
    
    echo ""
    gum style --foreground "$COLOR_MUTED" --align center \
        "Working directory: /workdir | Exit: Ctrl+D"
    echo ""

    sleep 2
    
    docker exec -it --user pokyuser "$BUILDER_CONTAINER" bash -c '
        export PS1="\[\e[38;5;245m\][\[\e[38;5;67m\]poky\[\e[38;5;245m\]]\[\e[0m\] \[\e[38;5;109m\]\w\[\e[0m\] \[\e[38;5;245m\]>\[\e[0m\] "
        export HISTSIZE=10000
        export HISTFILESIZE=20000
        export HISTCONTROL=ignoredups:erasedups
        
        cd /workdir
        clear
        
        echo -e "\e[38;5;67m Yocto Development Environment\e[0m"
        echo -e "\e[38;5;245m ────────────────────────────\e[0m"
        echo
        echo -e "\e[38;5;109mWorkspace:\e[0m"
        echo "  • shared/downloads/     - Package cache"
        echo "  • shared/sstate-cache/  - Build state cache"
        echo "  • shared/ccache/        - Compiler cache"
        echo "  • documentation/        - Project documentation"
        echo
        echo -e "\e[38;5;109mQuick Start:\e[0m"
        echo -e "  1. Create project directory"
        echo -e "     \e[38;5;245mmkdir -p yocto && cd yocto\e[0m"
        echo
        echo -e "  2. Clone Poky repository"
        echo -e "     \e[38;5;245mgit clone -b scarthgap git://git.yoctoproject.org/poky\e[0m"
        echo
        echo -e "  3. Initialize build environment"
        echo -e "     \e[38;5;245mcd poky && source oe-init-build-env\e[0m"
        echo
        echo -e "  4. Build minimal image"
        echo -e "     \e[38;5;245mbitbake core-image-minimal\e[0m"
        echo
        
        exec bash -l
    '
}

# Perform graceful environment shutdown
cmd_shutdown() {
    show_banner
    
    gum style \
        --foreground "$COLOR_DARK" \
        --bold \
        --align center \
        "ENVIRONMENT SHUTDOWN"
    
    echo ""
    echo ""
    
    gum style --foreground "$COLOR_MUTED" --align center \
        "This will stop all running containers." \
        "Your data will be preserved in volumes."
    
    echo ""
    
    if ! gum confirm "Proceed with shutdown?"; then
        # User cancelled - exit silently
        return 0
    fi
    
    echo ""
    
    local stopped
    stopped=$(stop_containers)
    
    echo ""
    
    gum style --foreground "$COLOR_SUCCESS" --bold --align center \
        "✓ SHUTDOWN COMPLETE"
    
    echo ""
    printf "  %-24s : %s\n" "Containers stopped" "$stopped"
    printf "  %-24s : %s\n" "Data status" "Preserved in volumes"
    printf "  %-24s : %s\n" "Network alias" "Remains active"
    echo ""
    gum style --foreground "$COLOR_MUTED" --align center \
        "Restart with: $SCRIPT_NAME start"
}

# Display concise help documentation
cmd_help() {
    show_banner
    
    gum style \
        --foreground "$COLOR_DARK" \
        --bold \
        --align center \
        "COMMAND REFERENCE"
    
    echo ""
    
    gum style --foreground "$COLOR_MUTED" "Usage:"
    echo "  $SCRIPT_NAME [command]"
    echo ""
    
    gum style --foreground "$COLOR_DARK" --bold "Available Commands:"
    echo ""
    
    # Define commands with proper spacing for alignment
    local -a commands=(
        "status:Display comprehensive environment status"
        "start:Initialize and start Yocto containers"
        "shell:Connect to Poky development container"
        "shutdown:Stop all containers gracefully"
        "version:Display version information"
        "help:Show this help message"
    )
    
    # Display commands with consistent alignment
    for cmd_info in "${commands[@]}"; do
        IFS=':' read -r cmd desc <<< "$cmd_info"
        # Use printf with fixed width for command name, then print colored version
        printf "  %-15s" "$cmd"
        # Move cursor back and print colored command over the plain text
        printf "\r  %s" "$(gum style --foreground "$COLOR_PRIMARY" "$cmd")"
        # Print description at the correct position
        printf "%*s%s\n" $((15 - ${#cmd})) "" "$desc"
    done
    
    echo ""
    gum style --foreground "$COLOR_INFO" --italic --align center \
        "Run $SCRIPT_NAME without arguments for interactive mode"
}

