# Enhanced error handler with contextual debugging information
handle_error() {
    local exit_code=$?
    local line_number="${1:-unknown}"
    local function_name="${2:-main}"
    
    trap - ERR
    
    gum log --level error "Operation failed" \
        function "$function_name" \
        line "$line_number" \
        code "$exit_code"
    
    exit "${exit_code}"
}

# Install comprehensive error trapping
trap 'handle_error ${LINENO} ${FUNCNAME:-main}' ERR

# Ensure terminal restoration on exit
trap 'printf "\033[?25h\033[0m"' EXIT

# Display application banner with ASCII art
show_banner() {
    gum style \
        --foreground "$COLOR_PRIMARY" \
        --align center \
        "$ASCII_BANNER"
}

# Verify Docker installation and daemon status
check_docker() {
    if ! command -v docker &> /dev/null; then
        gum log --level error "Docker is not installed or not in PATH"
        gum style --foreground "$COLOR_INFO" \
            "Install Docker Desktop: https://docker.com/products/docker-desktop"
        exit 1
    fi
    
    if ! docker info &> /dev/null; then
        gum log --level error "Docker daemon is not running"
        gum style --foreground "$COLOR_INFO" "Please start Docker Desktop"
        exit 1
    fi
}

# Verify gum installation for UI components
check_gum() {
    if ! command -v gum &> /dev/null; then
        echo "Error: gum is not installed"
        echo "Install with: brew install gum"
        exit 1
    fi
}

# -----------------------------------------------------------------------------
# Network Management Functions
# -----------------------------------------------------------------------------

# Configure network alias for SMB connectivity
configure_network() {
    if ifconfig "$LOOPBACK_INTERFACE" 2>/dev/null | grep -q "$SMB_ENDPOINT"; then
        # Already configured
        return 0
    fi
    
    if gum spin --spinner dot \
        --title "Configuring network infrastructure..." \
        -- sudo ifconfig "$LOOPBACK_INTERFACE" "$SMB_ENDPOINT" alias up; then
        
        sleep 1
        if ifconfig "$LOOPBACK_INTERFACE" 2>/dev/null | grep -q "$SMB_ENDPOINT"; then
            return 0
        fi
    fi
    
    return 1
}

# Analyze network connectivity status
check_network_status() {
    local status="inactive"
    local port_status="unreachable"
    
    if ifconfig "$LOOPBACK_INTERFACE" 2>/dev/null | grep -q "$SMB_ENDPOINT"; then
        status="active"
        
        if command -v nc &> /dev/null && nc -z "$SMB_ENDPOINT" "$SMB_PORT" 2>/dev/null; then
            port_status="accessible"
        fi
    fi
    
    echo "${status}:${port_status}"
}

# -----------------------------------------------------------------------------
# Container Management Functions
# -----------------------------------------------------------------------------

# Retrieve detailed container status with health information
get_container_status() {
    local container="$1"
    local status
    
    status=$(docker inspect -f '{{.State.Status}}' "$container" 2>/dev/null || echo "missing")
    
    if [[ "$status" == "running" ]]; then
        local started
        started=$(docker inspect -f '{{.State.StartedAt}}' "$container" 2>/dev/null | cut -d'T' -f1)
        echo "${status}:${started}"
    else
        echo "${status}:"
    fi
}

# Start containers with progress indication
start_containers() {
    local containers=("$FILESERVER_CONTAINER" "$BUILDER_CONTAINER")
    local failed=0
    
    for container in "${containers[@]}"; do
        local status
        status=$(docker inspect -f '{{.State.Status}}' "$container" 2>/dev/null || echo "missing")
        
        if [[ "$status" == "running" ]]; then
            # Container already running - skip silently
            continue
        elif [[ "$status" == "missing" ]]; then
            # Container missing - count as failure
            ((failed++))
        else
            if gum spin --spinner dot \
                --title "Starting $container..." \
                -- docker start "$container" &> /dev/null; then
                # Started successfully
                :
            else
                ((failed++))
            fi
        fi
    done
    
    return $failed
}

# Gracefully stop running containers
stop_containers() {
    local containers=("$BUILDER_CONTAINER" "$FILESERVER_CONTAINER")
    local stopped=0
    
    for container in "${containers[@]}"; do
        if docker ps -q -f "name=$container" | grep -q .; then
            if gum spin --spinner dot \
                --title "Stopping $container..." \
                -- docker stop "$container" &> /dev/null; then
                ((stopped++))
            fi
        fi
    done
    
    echo "$stopped"
}

# Wait for file server initialization
wait_for_fileserver() {
    local timeout=30
    local elapsed=0
    
    while [[ $elapsed -lt $timeout ]]; do
        if docker logs "$FILESERVER_CONTAINER" 2>&1 | grep -q "STATUS=daemon 'smbd' finished starting up and ready to serve connections"; then
            return 0
        fi
        sleep 1
        ((elapsed++))
    done
    
    return 1
}

# -----------------------------------------------------------------------------
# Storage Analysis Functions
# -----------------------------------------------------------------------------

# Analyze storage volume usage and contents
analyze_storage() {
    if ! docker volume inspect "$WORKSPACE_VOLUME" &> /dev/null; then
        echo "missing:0:0:0:0:0"
        return
    fi
    
    if docker ps -q -f "name=$BUILDER_CONTAINER" | grep -q .; then
        local size_info
        size_info=$(docker exec "$BUILDER_CONTAINER" df -h /workdir 2>/dev/null | tail -1)
        
        if [[ -n "$size_info" ]]; then
            local total=$(echo "$size_info" | awk '{print $2}')
            local used=$(echo "$size_info" | awk '{print $3}')
            local percent=$(echo "$size_info" | awk '{print $5}')
            
            local counts
            counts=$(docker exec "$BUILDER_CONTAINER" bash -c '
                files=$(find /workdir -type f 2>/dev/null | wc -l)
                dirs=$(find /workdir -type d 2>/dev/null | wc -l)
                echo "${files}:${dirs}"
            ' 2>/dev/null || echo "0:0")
            
            echo "active:${total}:${used}:${percent}:${counts}"
            return
        fi
    fi
    
    echo "active:unknown:unknown:unknown:0:0"
}

