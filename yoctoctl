# Interactive menu system with continuous operation loop
cmd_interactive() {
    while true; do
        clear
        show_banner
        
        # Environment status check
        local running=0
        docker ps -q -f "name=$FILESERVER_CONTAINER" | grep -q . && ((running++)) || true
        docker ps -q -f "name=$BUILDER_CONTAINER" | grep -q . && ((running++)) || true
        
        local status_msg="Environment Stopped"
        local status_color="$COLOR_ERROR"
        
        if [[ $running -eq 2 ]]; then
            status_msg="All Systems Operational"
            status_color="$COLOR_SUCCESS"
        elif [[ $running -eq 1 ]]; then
            status_msg="Partial Operation"
            status_color="$COLOR_WARNING"
        fi
        
        gum style \
            --foreground "$status_color" \
            --align center \
            --bold \
            "$status_msg"
        
        echo ""
        
        # Menu selection
        local choice
        choice=$(gum choose \
            --cursor.foreground "$COLOR_PRIMARY" \
            --selected.foreground "$COLOR_PRIMARY" \
            --selected.bold \
            --header "Select Operation:" \
            --header.foreground "$COLOR_DARK" \
            --header.bold \
            "View Status" \
            "Start Environment" \
            "Development Shell" \
            "Shutdown Environment" \
            "Help" \
            "Version" \
            "Exit")
        
        case "$choice" in
            "View Status")
                clear
                cmd_status
                echo ""
                gum input --placeholder "Press Enter to continue..."
                ;;
            "Start Environment")
                clear
                cmd_start
                echo ""
                gum input --placeholder "Press Enter to continue..."
                ;;
            "Development Shell")
                clear
                cmd_shell
                ;;
            "Shutdown Environment")
                clear
                cmd_shutdown
                echo ""
                gum input --placeholder "Press Enter to continue..."
                ;;
            "Help")
                clear
                cmd_help
                echo ""
                gum input --placeholder "Press Enter to continue..."
                ;;
            "Version")
                clear
                cmd_version
                echo ""
                gum input --placeholder "Press Enter to continue..."
                ;;
            "Exit")
                echo ""
                gum style --foreground "$COLOR_INFO" --align center \
                    "Thank you for using $SCRIPT_NAME"
                exit 0
                ;;
        esac
    done
}

# -----------------------------------------------------------------------------
# Main Entry Point
# -----------------------------------------------------------------------------

# Main program entry point with command dispatch
main() {
    # Verify critical dependencies
    check_gum
    check_docker
    
    # Command dispatch with default to interactive mode
    case "${1:-interactive}" in
        interactive)
            cmd_interactive
            ;;
        status)
            cmd_status
            ;;
        start)
            cmd_start
            ;;
        shell)
            cmd_shell
            ;;
        shutdown|stop)
            cmd_shutdown
            ;;
        help|--help|-h)
            cmd_help
            ;;
        version|--version|-v)
            cmd_version
            ;;
        *)
            gum log --level error "Unknown command: ${1}"
            echo ""
            gum style --foreground "$COLOR_MUTED" \
                "Run '$SCRIPT_NAME help' for usage information"
            exit 1
            ;;
    esac
}

# Execute main program
main "$@"